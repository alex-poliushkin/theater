stage tooling-smoke

scenario verify-items(item_id: string!)
  act fetch
    # helper data remains formatter-stable
    prop item_list = inventory.http.get(url: "https://api.example.test/items", session: "none") | json.decode
    do action.http
      method: "GET"
      url: "https://api.example.test/items"
      session: "none"
      headers: object {
        Accept: "application/json",
        "x-trace.id": "tooling"
      }
    expect has-item: field(body) | decode(json) | path("/items") has item where (
      path("/id") == $item_id,
      path("/kind") == "sample"
    )
    export item_label = field(body) | decode(json) | path("/items") | pick where (
      path("/id") == $item_id,
      path("/kind") == "sample"
    ) | path("/label") | regexp(pattern: r"^([A-Za-z]+)$", group: 1)

call verify = verify-items(item_id: "item-123")
