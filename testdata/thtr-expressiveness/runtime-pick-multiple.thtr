stage pick-multiple

scenario select-item(item_id: string!)
  act fetch
    do action.fixture.items(case: "multiple")
    export selected_status = field(body) | decode(json) | path("/items") | pick where (
      path("/id") == $item_id,
      path("/kind") == "sample"
    ) | path("/status")

call wait = select-item(item_id: "item-123")
