stage pick-zero

scenario mail/wait(email: string!)
  act poll
    do action.fixture.notifications(case: "zero")
    export otp = field(body) | decode(json) | path("/items") | pick where (
      path("/receiverAddress") == $email,
      path("/subject") contains "Verification Code"
    ) | path("/body") | regexp(pattern: r"([0-9]{6})", group: 1)

call wait = mail/wait(email: "demo@example.test")
